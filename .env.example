# .env.example

# Copy this file to .env and fill in your actual credentials.
# The .env file is ignored by git.

# ── Django ──
DJANGO_SECRET_KEY=          # Leave blank locally (uses insecure default)
DJANGO_DEBUG=True           # Set to False in production

# ── Database ──
# Option A: Single DATABASE_URL (Render/Railway auto-set this)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Option B: Individual vars (local dev)
DB_ENGINE=django.db.backends.mysql
DB_NAME=ai_trader
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/0

# ── Broker API Credentials (Alpaca) ──
ALPACA_API_KEY=YOUR_API_KEY
ALPACA_API_SECRET=YOUR_SECRET_KEY
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# ── Trading Mode ──
IS_LIVE=False               # Set to True for live trading